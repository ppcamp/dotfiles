# syntax=docker/dockerfile:1

FROM debian:trixie-slim AS git-builder
# ---- Build latest git from source
# (Debian's packaged git lags upstream releases)

RUN apt update && apt install -y --no-install-recommends \
    ca-certificates \
    curl \
    build-essential \
    pkg-config \
    libssl-dev \
    libcurl4-openssl-dev \
    libexpat1-dev \
    zlib1g-dev \
    gettext \
    perl \
    && rm -rf /var/lib/apt/lists/*

ARG GIT_VERSION=2.55.0
RUN curl -fsSL "https://mirrors.edge.kernel.org/pub/software/scm/git/git-${GIT_VERSION}.tar.gz" -o /tmp/git.tar.gz \
    && tar -xzf /tmp/git.tar.gz -C /tmp \
    && cd "/tmp/git-${GIT_VERSION}" \
    && make prefix=/usr/local NO_RUST=1 -j"$(nproc)" all \
    && make prefix=/usr/local NO_RUST=1 DESTDIR=/out install \
    && cd / \
    && rm -rf /tmp/git.tar.gz "/tmp/git-${GIT_VERSION}"

#--------------------------------- Final image ---------------------------------
FROM debian:trixie

# Install base system packages, plus git's runtime libraries
RUN apt update && apt install -y \
    sudo \
    binutils \
    gdb \
    strace \
    lsof \
    file \
    curl \
    wget \
    systemd \
    libpam-systemd \
    pipewire-audio-client-libraries \
    ca-certificates \
    gnupg \
    zsh \
    jq \
    unzip \
    tar \
    gzip \
    xz-utils \
    libarchive-tools \
    libcurl4 \
    libexpat1 \
    zlib1g \
    g++ \
    gcc \
    perl \
    && rm -rf /var/lib/apt/lists/*

COPY --from=git-builder /out/usr/local /usr/local

# Tools available via apt
RUN apt update && apt install -y \
    bat \
    btop \
    fd-find \
    fzf \
    ripgrep \
    lazygit \
    meld \
    neovim \
    kitty \
    procs \
    hyperfine \
    sqlite3 \
    postgresql-client \
    rsync \
    && rm -rf /var/lib/apt/lists/*

# Get Chezmoi
RUN sh -c "$(curl -fsLS get.chezmoi.io)" -- -b /usr/local/bin

WORKDIR /root

CMD ["/bin/zsh"]
