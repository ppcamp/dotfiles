{{- if has "magick" .scripts -}}
#!/usr/bin/env bash

{{ template "helpers.tmpl" . }}

# This script installs ImageMagick as a portable AppImage.

pkgCreator=ImageMagick
pkg=ImageMagick
version=7.1.2-11

echo "🚀 Installing magick $version"

tmp=$(mktemp -d)
cd "$tmp"

# downloading package
getfile "https://github.com/$pkgCreator/$pkg/releases/latest/download/${pkg}-578d60d-clang-x86_64.AppImage"
mv "${pkg}-578d60d-clang-x86_64.AppImage" magick

pkg=magick
binName=magick

{{ template "install_home.tmpl" . }}

{{ end -}}
