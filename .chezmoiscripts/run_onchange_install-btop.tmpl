{{- if has "btop" .scripts -}}
#!/usr/bin/env bash

{{ template "helpers.tmpl" . }}

# This script installs btop, a resource monitor that shows system usage and
# statistics in a graphical interface.

pkgCreator=aristocratos
pkg=btop

{{ template "github_setup.tmpl" . }}


# downloading package
getFileToStdin "https://github.com/$pkgCreator/$pkg/releases/latest/download/$pkg-x86_64-unknown-linux-musl.tar.gz" \
  | tar -xzC . --transform='s|.*/||'

{{ template "install_home.tmpl" . }}

{{ end -}}
