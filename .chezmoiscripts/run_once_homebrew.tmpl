{{- if has "homebrew" .scripts -}}
#!/usr/bin/env bash

{{ template "helpers.tmpl" . }}

loginstall "Homebrew in /home dir"
curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh

tip $' Add \'eval "$(<Homebrew prefix path>/bin/brew shellenv)"\''

