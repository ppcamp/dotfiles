#!/usr/bin/env bash
# vim: ts=2 sts=2 sw=2 et

{{ template "helpers.tmpl" . }}

################################################################################

info "Creating additional dirs"
mkdir -p $HOME/.local/share/man/man1
mkdir -p $HOME/.config/shell/completions

################################################################################

# Install additional local packages
tmp=$(mktemp -d)
pkg={{ joinPath .installDirs.home "jq" }}
cd $tmp
pkgCreator=jqlang
pkg=jq
{{ template "github_setup.tmpl" . }}
getGithubFileStdin jq-linux-amd64 > $pkg
chmod 755 $pkg
{{ template "install_home.tmpl" . }}
