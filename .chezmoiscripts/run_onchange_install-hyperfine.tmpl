{{- if has "hyperfine" .scripts -}}
#!/usr/bin/env bash

{{ template "helpers.tmpl" . }}

# This script installs hyperfine, a command-line benchmarking tool.

pkgCreator=sharkdp
pkg=hyperfine

{{ template "github_setup.tmpl" . }}

# downloading package
getFileToStdin "https://github.com/$pkgCreator/${pkg}/releases/latest/download/${pkg}-${version}-x86_64-unknown-linux-musl.tar.gz" \
  | tar -xzC . --transform='s|.*/||'

{{ template "install_home.tmpl" . }}

{{ end -}}
