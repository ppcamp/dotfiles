{{- if has "just" .scripts -}}
#!/usr/bin/env bash

{{ template "helpers.tmpl" . }}

# This script installs just, a command runner for tasks defined in a justfile.

pkgCreator=casey
pkg=just

{{ template "github_setup.tmpl" . }}

# downloading package
getGithubFileStdin "${pkg}-${version#v}-x86_64-unknown-linux-musl.tar.gz" \
  | tar -xzC .

{{ template "install_home.tmpl" . }}

{{ end -}}
