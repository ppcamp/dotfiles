{{- if has "asdf" .scripts -}}
#!/usr/bin/env bash

{{ template "helpers.tmpl" . }}

# This script installs asdf-vm, a version manager for multiple languages.

info "Installing all plugins required by .tool-versions file"

prettyprint 'GRAY' "   Check your '~/.tool-versions' file."

cd {{ .chezmoi.homeDir }}

grep -oE '^[a-z]*' .tool-versions | xargs -I% asdf plugin add % &>/dev/null

# FIX for LUA_ROCKS (without this, neither the previous version works)
export ASDF_LUA_LUAROCKS_VERSION=3.12.2

asdf install &>/dev/null

# do an asdf reshim to guarantee that packages are now visible and asdf shell
# (wrapper) files, under $HOME/.local/bin point to correct asdf tool version
asdf reshim &>/dev/null

info "Adding plugins"
while read line; do
  if [[ $line =~ ^# ]]; then
    continue
  fi

  plugin=$(echo $line | cut -d ' ' -f 1)
  info "  - $plugin"
  asdf plugin add "$plugin"  &>/dev/null || true
done < "{{ .chezmoi.homeDir }}/.tool-versions"

asdf reshim

packages_golang() {
  declare -A packages=(
    [asmfmt]='github.com/klauspost/asmfmt/cmd/asmfmt@latest'
    [dlv]='github.com/go-delve/delve/cmd/dlv@latest'
    [errcheck]='github.com/kisielk/errcheck@latest'
    [fillstruct]='github.com/davidrjenni/reftools/cmd/fillstruct@master'
    [godef]='github.com/rogpeppe/godef@latest'
    [goimports]='golang.org/x/tools/cmd/goimports@master'
    [revive]='github.com/mgechev/revive@latest'
    [gopls]='golang.org/x/tools/gopls@latest'
    [golangci-lint]='github.com/golangci/golangci-lint/v2/cmd/golangci-lint@latest'
    [staticcheck]='honnef.co/go/tools/cmd/staticcheck@latest'
    [gomodifytags]='github.com/fatih/gomodifytags@latest'
    [gotags]='github.com/jstemmer/gotags@master'
    [impl]='github.com/josharian/impl@main'
    [motion]='github.com/fatih/motion@latest'
    [iferr]='github.com/koron/iferr@master'
  )

  declare -A categories=(
    [asmfmt]='formatting'
    [dlv]='debugging'
    [errcheck]='linting'
    [fillstruct]='codegen'
    [godef]='navigation'
    [goimports]='formatting'
    [revive]='linting'
    [gopls]='lsp'
    [golangci-lint]='linting'
    [staticcheck]='linting'
    [gomodifytags]='codegen'
    [gotags]='navigation'
    [impl]='codegen'
    [motion]='navigation'
    [iferr]='codegen'
  )

  declare -A descriptions=(
    [asmfmt]='Go assembly formatter'
    [dlv]='Go debugger'
    [errcheck]='Check for unchecked errors'
    [fillstruct]='Fill struct literals with zero values'
    [godef]='Find symbol definitions'
    [goimports]='Manage import lines automatically'
    [revive]='Extensible Go linter'
    [gopls]='Official Go language server'
    [golangci-lint]='Aggregated linters runner'
    [staticcheck]='Static analysis tool'
    [gomodifytags]='Modify struct field tags'
    [gotags]='ctags-compatible tag generator'
    [impl]='Generate interface method stubs'
    [motion]='Navigate between functions/methods'
    [iferr]='Insert if err != nil checks'
  )

  echo
  info "  Installing GO packages"
  for tool in "${!packages[@]}"; do
  info "$(printf "   [%-10s] %-14s - %s" "${categories[$tool]}" "$tool" "${descriptions[$tool]}")"

  go install "${packages[$tool]}" &>/dev/null
  done
}

echo
while read -p "    Do you want to install Go tools? [y/N] " -n 1 -r; do
  echo
  if [[ $REPLY =~ ^[Yy]$ ]]; then
    packages_golang
  else
    warn "Skipping Go tools installation."
  fi
  break
done

packages_js() {
  declare -A categories=(
    [zx]='scripting'
  )

  declare -A descriptions=(
    [zx]='A tool for writing better scripts in JavaScript'
  )

  echo
  info "  Installing JS packages"
  for pkg in "${!descriptions[@]}"; do
    info "$(printf "   [%-10s] %-14s - %s" "${categories[$pkg]}" "$pkg" "${descriptions[$pkg]}")"

    # if bun is installed use it, otherwise fallback to npm
    if command -v bun &>/dev/null; then
      tool="bun"
    else
      tool="npm"
    fi

    $tool install -g "${pkg}" &>/dev/null
  done
}


echo
while read -p "    Do you want to install Javascript tools? [y/N] " -n 1 -r; do
  echo
  if [[ $REPLY =~ ^[Yy]$ ]]; then
    packages_js
  else
    warn "Skipping JS tools installation."
  fi
  break
done


# reshim, so it gets shown at PATH
# do an asdf reshim to guarantee that packages are now visible and asdf shell
# (wrapper) files, under $HOME/.local/bin point to correct asdf tool version
asdf reshim &>/dev/null

# tools such as jetbrains ide relies on calling actual binary, and does't
# support shell files as entrypoint for application
tip "The asdf install shell files in your path that points to version set at\n" \
"      .tool-versions file. Some tools need the actual binary, thus, call 'asdf \n"\
"        which PLUGIN_NAME' to get actual binary path."

{{ end -}}
