{{- if has "micro" .scripts -}}
#!/usr/bin/env bash

# Install micro, a modern text editor with on-demand file reading

pkgCreator=micro-editor
pkg=micro
tmp=$(mktemp -d)

# openning tmp folder
cd $tmp

# getting version
version=$(curl -sL https://api.github.com/repos/$pkgCreator/$pkg/releases/latest | jq -r .tag_name)

echo "🚀 Installing $pkg $version"

# downloading package
curl -sLo - https://github.com/$pkgCreator/$pkg/releases/latest/download/${pkg}-${version#v}-linux64.tar.gz |
	tar -xzC . --transform='s|.*/||'

# installing it
install -m 755 $pkg {{ .installDirs.home }}

# rm {{ joinPath .installDirs.home "$pkg" }}

{{ end -}}
