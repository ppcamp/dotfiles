#set -euo pipefail
pad=''

get_version() {
  local pkg=$1

  {{- if eq .configs.os "apt" }}
    LANG=en-us.UTF8 apt-cache policy $pkg | grep Candidate | awk '{print $2}'

  {{- else if eq .configs.os "dnf" }}
    arch=$(uname -m) # required for dnf

    if dnf -q list "$pkg.$arch" >/dev/null 2>&1; then
      # tries to check if it is using an unspecified arch
      dnf -q list "$pkg.$arch" | grep $pkg | awk '{print $2}'
    else
      dnf -q list "$pkg.noarch" | grep $pkg | awk '{print $2}'
    fi
  {{- end }}
}

install_pkg() {
  name=${pkg:-$1}
  local pkg=$1

  if is_installed $pkg; then
    # echo -e "${pad}\e[32m✅ Installed:\e[0m $pkg"
    echo -e "${pad}🚀 Installing: $name"
    return 0
  fi

  echo "🚀 Installing: ${pkg} $version"
  {{- if eq .configs.os "apt" }}
    sudo apt install -qq -y $pkg >/dev/null 2>&1
  {{- else if eq .configs.os "dnf" }}
    sudo dnf install -qy $pkg >/dev/null 2>&1
  {{- end }}
}

is_installed() {
  local pkg=$1

  {{- if eq .configs.os "apt" }}
    dpkg -s $pkg >/dev/null 2>&1
  {{- else if eq .configs.os "dnf" }}
    dnf list -q --installed | grep "^$pkg" >/dev/null 2>&1
  {{- end }}
}

update_package_list() {
  {{- if eq .configs.os "apt" }}
    sudo apt update -qq >/dev/null 2>&1
  {{- else if eq .configs.os "dnf" }}
    sudo dnf update --minimal -y >/dev/null 2>&1
  {{- end }}
}

getFileToStdin() {
	curl -sLo - $@
}

getfile() {
	curl -sLO $@
}

prettyprint() {
	color=$1
	shift
	text=$*
	rcolor='\033[0m'

	printf "%b${text}%b\n" "${COLOR_MAP[$color]}" "${rcolor}"
}

tip() {
  tipnl "$*"
  echo
}

tipnl() {
  text='   💡 Tip: '
  args="$*"
  printf "%b${text}%b${args}" "${COLOR_MAP[TIP]}" "${COLOR_MAP[RESET]}"
}

warn() {
  warnnl "$*"
  echo
}

warnnl() {
  text='   ⚠️ Warn: '
  args="$*"
  printf "%b${text}%b${args}" "${COLOR_MAP[WARN]}" "${COLOR_MAP[RESET]}"
}

info() {
  infonl "$*"
  echo
}

infonl() {
  text='   📌 Info: '
  args="$*"
  printf "%b${text}%b${args}" "${COLOR_MAP[INFO]}" "${COLOR_MAP[RESET]}"
}

log() {
  lognl "$*"
  echo
}

lognl() {
  text='   ⚙️ Log: '
  args="$*"
  printf "%b${text}%b${args}" "${COLOR_MAP[SETTING]}" "${COLOR_MAP[RESET]}"
}

declare -A COLOR_MAP
COLOR_MAP=(
  [TIP]=$'\e[0;32m'
  [WARN]=$'\e[0;33m'
  [INFO]=$'\e[0;36m'
  [SETTING]=$'\e[38;5;103m'
  [DEFAULT]=$'\e[0m'
  [RESET]=$'\e[0m'
  [FG_UNDERLINE]=$'\e[4m'
  [GRAY]=$'\e[2;37m'
)


function colorize() {
  __help_colorize() {
    echo "Usage: colorize COLOR TEXT"
    echo "Alternativaly, you may use other commands as:"
    echo "--list   to list all colors in color map"
    echo "--len    number of colors registered"
    echo "--help   this helper"
    echo "--fg     colorize using a number between [0,255]"
  }

  if [ -z $1 ]; then
    __help_colorize
    return 1
  fi

  case $1 in
    --help)
      __help_colorize
      ;;

    --fg)
      if [ $# -ne 3 ]; then
        echo "Usage: colorize --fg COLOR[0,255] TEXT"
        return 1
      fi
      echo -ne "\e\033[38;5;$2m$3${COLOR_MAP[RESET]}";
      ;;

    --list)
      local i=0
      for color in "${!COLOR_MAP[@]}"; do
        let i++
        printf "$i $(colorize $color $color)\n"
      done
      ;;

    --len)
      printf "${#COLOR_MAP[@]}\n"
      ;;

    *)
      if [ $# -ne 2 ]; then
        echo "Usage: colorize COLOR TEXT"
        return 1
      fi
      for color in "${!COLOR_MAP[@]}"; do
        if [ $1 = $color ]; then
          printf "${COLOR_MAP[$color]}${2}${COLOR_MAP[RESET]}"
          return 0;
        fi
      done

      printf "$2"
      return 1;
      ;;
  esac
}

tmp=$(mktemp -d)
cd "$tmp"

